# ===== Sao chép thành .env rồi chỉnh sửa =====
# Kiến trúc một-cho-tất-cả: Postgres + S3, mọi phase chỉ khác endpoint/credentials.
# Local dev: chạy backing services bằng Docker  ->  docker compose up -d

# ----- Postgres (docker-compose đọc POSTGRES_*) -----
POSTGRES_USER=ktx
POSTGRES_PASSWORD=doi_mat_khau_manh
POSTGRES_DB=ktx
POSTGRES_PORT=5432

DATABASE_URL=postgres://ktx:doi_mat_khau_manh@localhost:5432/ktx
# BẬT SSL mặc định (DB cloud). Local Postgres không SSL -> đặt disable:
PGSSL=disable

# ----- Bảo mật -----
# Sinh: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"  (>=16 ký tự)
JWT_SECRET=chuoi_ngau_nhien_dai_giu_bi_mat
# true khi phục vụ qua HTTPS (staging/prod), false khi chạy http local
COOKIE_SECURE=false

ADMIN_USERNAME=admin
ADMIN_PASSWORD=doi_mat_khau_manh_o_day
DORM_NAME=Ký túc xá Nội trú Esuhai
PORT=3000

# ----- Object storage S3 (local: MinIO; staging/prod: Supabase Storage / AWS S3) -----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=ktxminio
S3_SECRET_KEY=doi_secret_minio_manh
S3_CCCD_BUCKET=cccd
S3_INTRO_BUCKET=intro
S3_PORT=9000
S3_CONSOLE_PORT=9001

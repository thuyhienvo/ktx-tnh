# ===== Sao chép file này thành .env rồi chỉnh sửa =====
# cp .env.example .env   (Windows: copy .env.example .env)

# ----- Kết nối CSDL -----
# Dùng PostgreSQL của Supabase (session pooler, IPv4, có SSL).
# Lấy ở Supabase > Project Settings > Database > Connection string (Session pooler, port 5432).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Đặt PGSSL=disable nếu chạy Postgres nội bộ không SSL (mặc định BẬT SSL cho DB cloud)
# PGSSL=disable

# Cổng chạy app
PORT=3000

# ----- Bảo mật đăng nhập -----
# Chuỗi ngẫu nhiên dài: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=hay_doi_chuoi_bi_mat_that_dai_va_ngau_nhien

# ----- Tài khoản quản trị tạo sẵn lần đầu (BẮT BUỘC đổi mật khẩu ở lần đăng nhập đầu) -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=doi_mat_khau_manh_o_day

# Tên ký túc xá hiển thị
DORM_NAME=Ký túc xá Nội trú Esuhai

# ----- Supabase Storage (lưu ảnh CCCD + ảnh giới thiệu) -----
SUPABASE_URL=https://<project-ref>.supabase.co
# service_role key (Supabase > Project Settings > API). CHỈ dùng ở server, KHÔNG lộ client.
SUPABASE_SERVICE_KEY=<service_role_key>
SUPABASE_CCCD_BUCKET=cccd
SUPABASE_INTRO_BUCKET=intro
